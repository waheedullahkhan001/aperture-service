# Copy to .env and fill in. Generation commands in comments.
# UC-17: all environment-specific config lives here — no code changes needed.

# postgres + backend share this password
DB_PASSWORD=change-me

# JWT signing secret: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=change-me

# Shared secret between mediamtx and the backend.
# MUST be URL-safe (hex): openssl rand -hex 32
# (it travels in a URL query and through sed — base64 chars would corrupt it)
MEDIAMTX_WEBHOOK_SECRET=change-me

# Recordings root inside the containers — the default matches the compose volume
# mount AND mediamtx's recordPath; only override if you change all three together.
# APP_RECORDINGS_PATH=/data/recordings

# Public hostname (nginx server_name + certbot). Laptop dev: localhost
DOMAIN=localhost

# Let's Encrypt registration email (server only)
CERTBOT_EMAIL=you@example.com

# Browser-facing streaming base URLs. With nginx in front these are SAME-ORIGIN:
# Laptop: http://localhost   Server: https://aperture.mimarlogics.com
# (direct-port values like http://localhost:8888 also work, bypassing nginx)
MEDIAMTX_HLS_BASE=http://localhost
MEDIAMTX_WEBRTC_BASE=http://localhost

# Watch links in alert emails are built from this origin.
# Laptop: http://localhost   Server: https://aperture.mimarlogics.com
APP_PUBLIC_ORIGIN=http://localhost

# SMTP — local dev points at the mailpit container (any user/pass accepted).
# Real-provider example (implicit TLS on submission port 465):
#   SMTP_HOST=mail.example.com  SMTP_PORT=465  SMTP_SSL=true
#   SMTP_USER=no-reply@example.com  APP_MAIL_FROM=no-reply@example.com
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SSL=false
SMTP_USER=aperture
SMTP_PASSWORD=aperture
APP_MAIL_FROM=aperture@localhost
